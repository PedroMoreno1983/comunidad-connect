# Public browser configuration
NEXT_PUBLIC_SITE_URL=https://conviveconnect.com
NEXT_PUBLIC_SUPABASE_URL=tu_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key
NEXT_PUBLIC_ENABLE_DEMO=false
NEXT_PUBLIC_PRIVACY_RESPONSIBLE_NAME=Razón social del proveedor
NEXT_PUBLIC_PRIVACY_RESPONSIBLE_ADDRESS=Domicilio legal completo, Chile
NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=privacidad@tu-dominio.cl

# Geocoding (optional; falls back to OpenStreetMap/Nominatim if Mapbox is not set)
MAPBOX_ACCESS_TOKEN=
GEOCODING_USER_AGENT=ConviveConnect/1.0 (https://conviveconnect.com)

# Supabase server-only access
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# AI providers
ANTHROPIC_API_KEY=tu_anthropic_api_key
GEMINI_API_KEY=tu_gemini_api_key
OPENAI_API_KEY=tu_openai_api_key
OPENAI_IMAGE_MODEL=dall-e-3
VOYAGE_API_KEY=tu_voyage_api_key
VOYAGE_EMBEDDING_MODEL=voyage-3.5-lite
AI_HEALTH_TOKEN=token_largo_para_health_ai
AI_BUDGET_ENFORCEMENT=on
AI_DEFAULT_MONTHLY_TOKEN_LIMIT=1000000
AI_DEFAULT_MONTHLY_IMAGE_LIMIT=30
AI_DEFAULT_MONTHLY_COST_LIMIT_CENTS=2500
AI_RESIDENT_DAILY_TOKEN_LIMIT=8000
AI_STAFF_DAILY_TOKEN_LIMIT=50000
AI_HEAVY_DAILY_LIMIT=10

# Email
RESEND_API_KEY=tu_resend_api_key
FROM_EMAIL=Convive Connect <notificaciones@tu-dominio.cl>

# Marketing / Instagram Reels
META_APP_ID=tu_meta_app_id
META_APP_SECRET=tu_meta_app_secret
META_GRAPH_API_VERSION=v21.0
META_REDIRECT_URI=https://conviveconnect.com/api/marketing/instagram/callback
META_OAUTH_STATE_SECRET=token_largo_para_firmar_oauth
META_TOKEN_ENCRYPTION_KEY=token_largo_para_cifrar_tokens
MARKETING_VIDEO_RENDER_WEBHOOK_URL=
MARKETING_VIDEO_RENDER_TOKEN=

# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=tu_twilio_account_sid
TWILIO_AUTH_TOKEN=tu_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_WEBHOOK_SECRET=tu_webhook_secret

# Payments / Haulmer
HAULMER_ACCOUNT_ID=tu_account_id
HAULMER_SECRET_KEY=tu_secret_key
HAULMER_ENVIRONMENT=production
HAULMER_SHOP_NAME=Convive Connect
HAULMER_DEFAULT_CUSTOMER_PHONE=+56900000000

# IoT webhooks use an independent communities.iot_webhook_secret per tenant.
# Do not configure a shared/global webhook secret.

# Platform administration
SUPERADMIN_EMAILS=admin@tu-dominio.cl
